generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Player {
  id        String   @id @default(cuid())
  nickname  String
  avatarId  String
  sessionId String   @unique
  createdAt DateTime @default(now())

  hostedGames Game[]        @relation("host")
  gamePlayers GamePlayer[]
  votes       Vote[]        @relation("voter")
  votedFor    Vote[]        @relation("voted")
  submissions Submission[]
}

model Game {
  id           String   @id @default(cuid())
  roomCode     String   @unique
  status       String   @default("LOBBY")
  gameMode     String   @default("WORD_PLAY")
  maxPlayers   Int      @default(8)
  totalRounds  Int      @default(3)
  currentRound Int      @default(0)
  currentPhase String   @default("WAITING")
  hostId       String
  host         Player   @relation("host", fields: [hostId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  players GamePlayer[]
  rounds  Round[]
}

model GamePlayer {
  id       String  @id @default(cuid())
  gameId   String
  playerId String
  score    Int     @default(0)
  isReady  Boolean @default(false)
  isOnline Boolean @default(true)

  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])

  @@unique([gameId, playerId])
}

model Round {
  id             String @id @default(cuid())
  gameId         String
  roundNumber    Int
  normalPrompt   String
  imposterPrompt String
  imposterId     String

  game        Game         @relation(fields: [gameId], references: [id], onDelete: Cascade)
  submissions Submission[]
  votes       Vote[]

  @@unique([gameId, roundNumber])
}

model Submission {
  id        String   @id @default(cuid())
  roundId   String
  playerId  String
  content   String
  createdAt DateTime @default(now())

  round  Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])

  @@unique([roundId, playerId])
}

model Vote {
  id      String @id @default(cuid())
  roundId String
  voterId String
  votedId String

  round Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  voter Player @relation("voter", fields: [voterId], references: [id])
  voted Player @relation("voted", fields: [votedId], references: [id])

  @@unique([roundId, voterId])
}
